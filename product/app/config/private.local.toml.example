# A Stock 私密配置示例
#
# 用法：
# - 复制为 `product/app/config/private.local.toml`
# - 先保留 key，再逐项填写真实值
# - 该文件已加入 `.gitignore`，不会同步到远端仓库
#
# 说明：
# - 这里只放本地运行所需的敏感配置
# - 公开 SMTP 参数已经放入 `product/app/config/app.toml`
# - 启动脚本会在启动前检查这些值是否已补齐

[smtp]
password = ""

[secrets]
deepseek_api_key = ""
tushare_token = ""

[mysql]
user = ""
password = ""
